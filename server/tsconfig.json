{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "./dist",
    
    /* Monorepo resolution: Include both local src and shared types */
    "rootDirs": ["src", "../shared/src"],
    
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    
    "baseUrl": ".",
    "paths": {
      /* Maps the shared package alias to source for seamless local dev */
      "@rule-filter/shared": ["../shared/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}